# PLAID Credentials
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox
PLAID_PRODUCTS=auth,transactions,assets
PLAID_COUNTRY_CODES=US,CA

# Database
MONGODB_URI=mongodb+srv://your_user:your_password@cluster.mongodb.net/?appName=YourApp

# Persona Identity Verification
PERSONA_TEMPLATE_ID=itmpl_your_template_id

# Credit Pull API (Equifax/Experian Simulation)
CREDIT_API_KEY=your_credit_api_key
CREDIT_API_URL=https://api.experian.com/v1/creditreport

# Authentication
JWT_SECRET=your_jwt_secret_here

# Server Port
PORT=3000
